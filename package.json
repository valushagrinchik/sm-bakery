{
    "name": "admin-panel",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "NODE_OPTIONS='--inspect' next dev",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "format": "prettier --write \"**/*.{ts,tsx,md,mdx,css,scss}\"",
        "test": "next build",
        "docker": "docker build --target production -t admin-panel . && docker run -p 3000:3000 admin-panel",
        "docker:dev": "docker build --target dev -t admin-panel-dev . && docker run -p 3000:3000 admin-panel-dev",
        "libgen": "pnpm exec swagger-typescript-api -p https://dev-api.sanmartinbakery.com/api-doc-json/ -o ./src/shared/lib/sanMartinApi/",
        "libgen:dev": "pnpm exec swagger-typescript-api -p http://localhost:3000/api-doc-json -o ./src/shared/lib/sanMartinApi/"
    },
    "dependencies": {
        "@headlessui/react": "^2.2.0",
        "@heroicons/react": "^1.0.6",
        "@hookform/resolvers": "^3.9.0",
        "@tailwindcss/line-clamp": "^0.4.4",
        "@vis.gl/react-google-maps": "^1.4.0",
        "jsts": "1.6.2",
        "lodash": "^4.17.21",
        "next": "15.0.3",
        "next-intl": "^3.21.1",
        "react": "19.0.0-rc-ed15d500-20241110",
        "react-dom": "19.0.0-rc-ed15d500-20241110",
        "react-hook-form": "^7.53.1",
        "react-toastify": "^10.0.6",
        "socket.io-client": "^4.8.1",
        "universal-cookie": "^7.2.2",
        "uuid": "^11.0.3",
        "zod": "^3.23.8",
        "zustand": "^5.0.1"
    },
    "devDependencies": {
        "@types/jsts": "^0.17.24",
        "@types/lodash": "^4.17.13",
        "@types/node": "^20",
        "@types/react": "^18",
        "@types/react-dom": "^18",
        "@typescript-eslint/parser": "^8.8.0",
        "eslint": "^8",
        "eslint-config-next": "15.0.3",
        "eslint-config-prettier": "^9.1.0",
        "postcss": "^8",
        "prettier": "^3.3.3",
        "prettier-eslint": "^16.3.0",
        "swagger-typescript-api": "^13.0.22",
        "tailwind-merge": "^2.5.4",
        "tailwindcss": "^3.4.1",
        "typescript": "^5",
        "typescript-eslint": "^8.11.0"
    }
}
