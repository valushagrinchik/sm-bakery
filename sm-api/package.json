{
  "name": "san-martin-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "email-service:build": "nest build email-service",
    "sms-service:build": "nest build sms-service",
    "catalog-parsing-service:build": "nest build catalog-parsing-service",
    "notification-service:build": "nest build notification-service",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/san-martin-api/main",
    "email-service:start": "nest start email-service",
    "email-service:start:dev": "nest start email-service --watch",
    "email-service:start:debug": "nest start email-service --debug --watch",
    "email-service:start:prod": "node dist/apps/email-service/main",
    "sms-service:start": "nest start sms-service",
    "sms-service:start:dev": "nest start sms-service --watch",
    "sms-service:start:debug": "nest start sms-service --debug --watch",
    "sms-service:start:prod": "node dist/apps/sms-service/main",
    "catalog-parsing-service:start": "nest start catalog-parsing-service",
    "catalog-parsing-service:start:dev": "nest start catalog-parsing-service --watch",
    "catalog-parsing-service:start:debug": "nest start catalog-parsing-service --debug --watch",
    "catalog-parsing-service:start:prod": "node dist/apps/catalog-parsing-service/main",
    "notification-service:start": "nest start notification-service",
    "notification-service:start:dev": "nest start notification-service --watch",
    "notification-service:start:debug": "nest start notification-service --debug --watch",
    "notification-service:start:prod": "node dist/apps/notification-service/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/san-martin-api/test/jest-e2e.json",
    "sequelize": "sequelize-cli",
    "migration:create": "sequelize-cli migration:create --name",
    "migration:up": "sequelize-cli db:migrate",
    "migration:down": "sequelize-cli db:migrate:undo",
    "db:seed:create": "npx sequelize-cli seed:generate --name",
    "db:seed:run": "dotenvx run -- npx sequelize-cli db:seed:all",
    "db:seed:undo": "dotenvx run -- npx sequelize-cli db:seed:undo:all",
    "docker": "docker compose -f docker-compose.local.yml up --build -d",
    "docker:test": "docker compose -f docker-compose.test.yml up --build -d && jest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.682.0",
    "@getbrevo/brevo": "^2.2.0",
    "@nestjs/axios": "^3.1.2",
    "@nestjs/bull": "^10.2.2",
    "@nestjs/cache-manager": "^2.2.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.4.4",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/sequelize": "^10.0.1",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/websockets": "^10.4.15",
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^0.10.4",
    "axios": "^1.7.7",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.3",
    "bull": "^4.16.3",
    "cache-manager": "^5.7.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "countries-and-timezones": "^3.7.2",
    "crypto": "^1.0.1",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-jsdoc": "^50.3.1",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "firebase-admin": "^13.0.1",
    "google-auth-library": "^9.14.2",
    "ioredis": "^5.4.1",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "sequelize": "^6.37.4",
    "sequelize-cli": "^6.6.2",
    "sequelize-typescript": "^2.1.6",
    "socket.io-client": "^4.8.1",
    "tough-cookie": "^5.0.0",
    "verify-apple-id-token": "^3.1.2"
  },
  "devDependencies": {
    "@automock/adapters.nestjs": "^2.1.0",
    "@automock/jest": "^2.1.0",
    "@dotenvx/dotenvx": "^1.16.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.3.1",
    "@types/sequelize": "^4.28.20",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "bcryptjs": "^2.4.3",
    "cache-manager-redis-store": "^3.0.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^san-martin/san-martin-libs(|/.*)$": "<rootDir>/libs/san-martin-libs/src/$1",
      "@san-martin/san-martin-libs": "<rootDir>/libs/san-martin-libs/src"
    }
  }
}
