{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/san-martin-api/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/san-martin-api/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/san-martin-api",
  "projects": {
    "san-martin-api": {
      "type": "application",
      "root": "apps/san-martin-api",
      "entryFile": "main",
      "sourceRoot": "apps/san-martin-api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/san-martin-api/tsconfig.app.json"
      }
    },
    "email-service": {
      "type": "application",
      "root": "apps/email-service",
      "entryFile": "main",
      "sourceRoot": "apps/email-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/email-service/tsconfig.app.json"
      }
    },
    "san-martin-libs": {
      "type": "library",
      "root": "libs/san-martin-libs",
      "entryFile": "index",
      "sourceRoot": "libs/san-martin-libs/src",
      "compilerOptions": {
        "tsConfigPath": "libs/san-martin-libs/tsconfig.lib.json"
      }
    },
    "sms-service": {
      "type": "application",
      "root": "apps/sms-service",
      "entryFile": "main",
      "sourceRoot": "apps/sms-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/sms-service/tsconfig.app.json"
      }
    },
    "notification-service": {
      "type": "application",
      "root": "apps/notification-service",
      "entryFile": "main",
      "sourceRoot": "apps/notification-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notification-service/tsconfig.app.json"
      }
    }
  }
}